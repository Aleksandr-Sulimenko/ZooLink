erDiagram
    %% Reference Data Tables
    species {
        INTEGER id PK
        VARCHAR_50 code UK
        JSONB name_localized
        VARCHAR_10 market
        INTEGER sort_order
        BOOLEAN is_active
        UUID created_by FK
        UUID updated_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    breeds {
        INTEGER id PK
        INTEGER species_id FK
        VARCHAR_50 code
        JSONB name_localized
        INTEGER sort_order
        BOOLEAN is_active
        UUID created_by FK
        UUID updated_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (species_id, code)
    }
    cities {
        INTEGER id PK
        JSONB name_localized
        INTEGER sort_order
        BOOLEAN is_active
        UUID created_by FK
        UUID updated_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    health_certifications {
        INTEGER id PK
        VARCHAR_50 code
        JSONB name_localized
        VARCHAR_10 market
        INTEGER sort_order
        BOOLEAN is_active
        UUID created_by FK
        UUID updated_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (market, code)
    }
    genetic_markers {
        INTEGER id PK
        VARCHAR_50 code
        JSONB name_localized
        VARCHAR_10 market
        INTEGER sort_order
        BOOLEAN is_active
        UUID created_by FK
        UUID updated_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (market, code)
    }
    supported_languages {
        CHAR_2 code PK
        JSONB name_localized
        BOOLEAN is_active
        INTEGER display_order
        TIMESTAMPTZ created_at
    }

    %% Identity Domain
    users {
        UUID id PK
        VARCHAR_60 phone_hash
        VARCHAR_255 oauth_google_id
        VARCHAR_255 oauth_apple_id
        VARCHAR_255 oauth_telegram_id
        VARCHAR_255 oauth_vk_id
        VARCHAR_100 full_name
        INTEGER city_id FK
        TEXT avatar_url
        VARCHAR_255 email
        BOOLEAN email_verified
        VARCHAR_60 password_hash
        VARCHAR_20 role
        VARCHAR_10 principal_type
        VARCHAR_25 status
        TIMESTAMPTZ suspended_at
        INTEGER verification_attempts
        JSONB notification_prefs
        BOOLEAN is_active
        TIMESTAMPTZ last_login_at
        TIMESTAMPTZ deactivated_at
        TIMESTAMPTZ erased_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    %% Animal Domain
    animals {
        UUID id PK
        UUID owner_id FK
        UUID organization_id FK
        INTEGER species_id FK
        INTEGER breed_id FK
        JSONB breed_text_localized
        JSONB nickname_localized NOT NULL
        VARCHAR_10 sex
        DATE date_of_birth
        VARCHAR_100 color_coat
        VARCHAR_50 microchip_id
        VARCHAR_50 tattoo_brand_id
        BOOLEAN is_active
        JSONB health_records
        JSONB reproductive_data
        DATE owned_since
        UUID mother_id FK
        UUID father_id FK
        VARCHAR_100 pedigree_id
        JSONB health_test_results
        JSONB show_titles
        BOOLEAN is_visible_in_breeding_search
        VARCHAR_20 reproductive_status
        JSONB description_localized
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        TIMESTAMPTZ deactivated_at
    }
    animal_ownership_history {
        UUID id PK
        UUID animal_id FK
        UUID owner_id FK
        DATE start_date
        DATE end_date
        TEXT transfer_reason
        TIMESTAMPTZ created_at
    }
    ownership_transfers {
        UUID id PK
        UUID animal_id FK
        UUID from_user_id FK
        UUID to_user_id FK
        VARCHAR_20 status
        BOOLEAN from_confirmed
        BOOLEAN to_confirmed
        BOOLEAN payment_confirmed
        TEXT failure_reason
        TIMESTAMPTZ expires_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    digital_assets {
        UUID id PK
        UUID animal_id FK
        VARCHAR_30 asset_type
        VARCHAR_20 chain
        VARCHAR_120 contract_address
        VARCHAR_120 token_id
        VARCHAR_120 ipfs_cid
        TEXT metadata_uri
        VARCHAR_120 tx_hash
        VARCHAR_20 mint_status
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% ADR-0010: NFT readiness hook; gated by feature_toggles
    }

    %% Organization Domain
    organizations {
        UUID id PK
        VARCHAR_20 inn
        VARCHAR_20 kpp
        TEXT address
        VARCHAR_30 phone
        VARCHAR_255 email
        TEXT logo_url
        JSONB name_localized
        JSONB description_localized
        JSONB metadata
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    branches {
        UUID id PK
        UUID organization_id FK
        INTEGER city_id FK
        TEXT address
        VARCHAR_30 phone
        VARCHAR_255 email
        JSONB name_localized
        JSONB description_localized
        BOOLEAN is_headquarters
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    organization_users {
        UUID id PK
        UUID organization_id FK
        UUID user_id FK
        VARCHAR_20 role_in_org
        BOOLEAN is_primary
        DATE joined_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (organization_id, user_id)
    }

    %% Marketplace/Listings Domain
    listings {
        UUID id PK
        UUID animal_id FK
        UUID seller_id FK
        UUID organization_id FK
        UUID branch_id FK
        VARCHAR_20 listing_type
        JSONB title_localized
        JSONB description_localized
        BIGINT price_cents
        CHAR_3 currency
        INTEGER quantity
        VARCHAR_20 status
        VARCHAR_20 moderation_status
        TIMESTAMPTZ published_at
        TIMESTAMPTZ sold_at
        UUID transaction_id FK
        DOUBLE lat
        DOUBLE lng
        GEOGRAPHY location_point
        INTEGER search_radius_m
        BOOLEAN is_active
        TIMESTAMPTZ expires_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (animal_id, listing_type) WHERE status='ACTIVE'
    }
    listing_photos {
        UUID id PK
        UUID listing_id FK
        TEXT url
        INTEGER order_index
        TIMESTAMPTZ created_at
    }
    conversations {
        UUID id PK
        UUID listing_id FK
        UUID participant_a_id FK
        UUID participant_b_id FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    messages {
        UUID id PK
        UUID conversation_id FK
        UUID sender_id FK
        UUID recipient_id FK
        TEXT body
        TIMESTAMPTZ sent_at
        TIMESTAMPTZ read_at
        TIMESTAMPTZ created_at
    }

    %% Moderation Domain
    moderation_reasons {
        VARCHAR_50 code PK
        JSONB description_localized
        VARCHAR_20 applies_to
        BOOLEAN is_active
        TIMESTAMPTZ created_at
    }
    moderation_decisions {
        UUID id PK
        UUID moderator_id FK
        VARCHAR_20 entity_type
        UUID entity_id
        VARCHAR_20 decision
        VARCHAR_50 reason FK
        TEXT notes
        VARCHAR_10 actor_principal_type
        VARCHAR_20 actor_role
        UUID supersedes_decision_id FK
        BOOLEAN is_human_override
        TIMESTAMPTZ created_at
        %% append-only (immutable); ADR-0011 actor-snapshot + human-override chain (supersedes_decision_id self-ref)
    }

    %% Payment Domain
    payment_transactions {
        UUID id PK
        UUID user_id FK
        VARCHAR_255 gateway_transaction_id
        BIGINT amount_minor
        CHAR_3 currency
        VARCHAR_20 status
        VARCHAR_40 purpose_type
        UUID purpose_id
        VARCHAR_255 idempotency_key UK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    refunds {
        UUID id PK
        UUID payment_transaction_id FK
        VARCHAR_255 gateway_refund_id
        BIGINT amount_minor
        TEXT reason
        VARCHAR_20 status
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    %% Notification Domain
    notification_templates {
        UUID id PK
        VARCHAR_100 name
        VARCHAR_10 type
        TEXT subject_template
        TEXT body_template
        CHAR_2 language FK
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
        %% UK (name, type, language)
    }
    notification_logs {
        UUID id PK
        UUID user_id FK
        VARCHAR_10 type
        UUID template_id FK
        VARCHAR_255 recipient
        TEXT content
        VARCHAR_20 status
        JSONB provider_response
        VARCHAR_255 provider_message_id
        VARCHAR_255 idempotency_key UK
        INTEGER attempts
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    notification_suppressions {
        UUID id PK
        VARCHAR_255 recipient
        VARCHAR_10 channel
        VARCHAR_30 reason
        TIMESTAMPTZ created_at
        %% (recipient, channel) UNIQUE — hard-bounce / unsubscribe
    }

    %% Favorites & Saved Searches (MVP)
    favorites {
        UUID id PK
        UUID user_id FK
        UUID listing_id FK
        TIMESTAMPTZ created_at
        %% UK (user_id, listing_id)
    }
    saved_searches {
        UUID id PK
        UUID user_id FK
        VARCHAR_100 name
        JSONB filters
        DOUBLE lat
        DOUBLE lng
        INTEGER radius_m
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    content_reports {
        UUID id PK
        UUID reporter_id FK
        VARCHAR_20 entity_type
        UUID entity_id
        VARCHAR_50 reason
        TEXT notes
        VARCHAR_20 status
        UUID resolved_by FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    contact_reveals {
        UUID id PK
        UUID listing_id FK
        UUID viewer_id FK
        UUID seller_id FK
        TIMESTAMPTZ created_at
        %% ADR-0005: MVP "contact the seller" (no chat); audit + rate-limit source
    }

    %% Identity sessions & audit (round-4 integrity)
    refresh_tokens {
        UUID id PK
        UUID user_id FK
        VARCHAR_255 token_hash UK
        UUID family_id
        VARCHAR_120 device_label
        TIMESTAMPTZ issued_at
        TIMESTAMPTZ expires_at
        UUID rotated_from
        TIMESTAMPTZ revoked_at
        INET ip_address
        TEXT user_agent
        TIMESTAMPTZ last_used_at
        VARCHAR_40 revoked_reason
    }
    audit_log {
        UUID id PK
        UUID actor_id FK
        VARCHAR_20 actor_role
        VARCHAR_10 actor_principal_type
        VARCHAR_100 action
        VARCHAR_40 entity_type
        UUID entity_id
        INTEGER entity_id_int
        JSONB before_data
        JSONB after_data
        INET ip_address
        TEXT user_agent
        TIMESTAMPTZ created_at
        %% append-only
    }
    service_credentials {
        UUID id PK
        UUID agent_user_id FK
        VARCHAR_120 label
        VARCHAR_255 secret_hash
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ revoked_at
        UUID rotated_from FK
        %% ADR-0011 §5.3 agent service-auth FORM ONLY (gated)
    }

    %% Extensibility / System Tables
    feature_toggles {
        VARCHAR_100 key PK
        TEXT description
        BOOLEAN is_enabled
        INTEGER rollout_percentage
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
    outbox_events {
        UUID id PK
        VARCHAR_50 aggregate_type
        UUID aggregate_id
        VARCHAR_100 event_type
        JSONB payload
        TIMESTAMPTZ processed_at
        TIMESTAMPTZ created_at
        INTEGER attempts
        TEXT last_error
        TIMESTAMPTZ next_attempt_at
        TIMESTAMPTZ dead_lettered_at
    }

    %% Relationships
    species ||..o{ breeds : "contains"
    species ||..o{ animals : "classified as"
    breeds ||..o{ animals : "breed of"
    users }o..|| cities : "located in (optional)"
    users ||..o{ animals : "owns"
    users ||..o{ animal_ownership_history : "records ownership"
    users ||..o{ listings : "sells"
    users ||..o{ conversations : "participates as initiator"
    users ||..o{ conversations : "participates as recipient"
    users ||..o{ messages : "sends"
    users ||..o{ messages : "receives"
    animals ||..o{ animal_ownership_history : "has history"
    animals ||..o{ listings : "listed for"
    animals ||..o{ ownership_transfers : "transferred via"
    users ||..o{ ownership_transfers : "transfers (from/to)"
    animals ||..o{ digital_assets : "tokenized as"
    animals }o..|| animals : "mother of"
    animals }o..|| animals : "father of"
    listings ||..o{ listing_photos : "has photos"
    listings ||..o{ conversations : "has conversation"
    conversations ||..o{ messages : "contains"
    users ||..o{ favorites : "saves"
    listings ||..o{ favorites : "favorited by"
    users ||..o{ saved_searches : "saves search"
    users ||..o{ content_reports : "files report"
    users ||..o{ contact_reveals : "reveals/owns"
    listings ||..o{ contact_reveals : "contact revealed for"
    users ||..o{ refresh_tokens : "has sessions"
    users ||..o{ audit_log : "acted (nullable)"
    users ||..o{ service_credentials : "agent service-auth (gated)"
    service_credentials |o..o{ service_credentials : "rotated_from (rotation chain)"

    %% Organization Domain Relationships (junction = M:N resolved)
    organizations ||..o{ organization_users : "has members"
    users ||..o{ organization_users : "member of"
    organizations ||..o{ branches : "has"
    branches }o..|| cities : "located in"
    listings }o..|| organizations : "linked to (optional)"
    listings }o..|| branches : "linked to (optional)"
    animals }o..|| organizations : "owned by (optional)"

    %% Moderation / Payment / Notification Relationships
    users ||..o{ moderation_decisions : "decides"
    moderation_reasons ||..o{ moderation_decisions : "categorizes"
    moderation_decisions |o..o{ moderation_decisions : "human-override supersedes (ADR-0011)"
    users ||..o{ payment_transactions : "pays"
    payment_transactions ||..o{ refunds : "refunded by"
    payment_transactions |o..o{ listings : "settles (optional)"
    supported_languages ||..o{ notification_templates : "language of"
    notification_templates ||..o{ notification_logs : "rendered as"
    users ||..o{ notification_logs : "notified via"
