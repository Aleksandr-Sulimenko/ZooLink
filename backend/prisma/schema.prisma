generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model animal_ownership_history {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  animal_id       String    @db.Uuid
  owner_id        String    @db.Uuid
  start_date      DateTime  @db.Date
  end_date        DateTime? @db.Date
  transfer_reason String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  animals         animals   @relation(fields: [animal_id], references: [id], onUpdate: NoAction)
  users           users     @relation(fields: [owner_id], references: [id], onUpdate: NoAction)

  @@index([animal_id], map: "idx_aoh_animal")
  @@index([start_date, end_date], map: "idx_aoh_dates")
  @@index([owner_id], map: "idx_aoh_owner")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model animals {
  id                                         String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_id                                   String?                    @db.Uuid
  organization_id                            String?                    @db.Uuid
  species_id                                 Int
  breed_id                                   Int?
  breed_text_localized                       Json?
  nickname_localized                         Json
  sex                                        String                     @db.VarChar(10)
  date_of_birth                              DateTime                   @db.Date
  color_coat                                 String?                    @db.VarChar(100)
  microchip_id                               String?                    @db.VarChar(50)
  tattoo_brand_id                            String?                    @db.VarChar(50)
  description_localized                      Json                       @default("{\"en\": \"\", \"ru\": \"\"}")
  is_active                                  Boolean                    @default(true)
  health_records                             Json                       @default("[]")
  reproductive_data                          Json                       @default("[]")
  owned_since                                DateTime?                  @db.Date
  mother_id                                  String?                    @db.Uuid
  father_id                                  String?                    @db.Uuid
  pedigree_id                                String?                    @db.VarChar(100)
  health_test_results                        Json                       @default("[]")
  show_titles                                Json                       @default("[]")
  is_visible_in_breeding_search              Boolean                    @default(true)
  created_at                                 DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                                 DateTime                   @default(now()) @db.Timestamptz(6)
  deactivated_at                             DateTime?                  @db.Timestamptz(6)
  reproductive_status                        String                     @default("UNKNOWN") @db.VarChar(20)
  animal_ownership_history                   animal_ownership_history[]
  breeds_animals_breed_idTobreeds            breeds?                    @relation("animals_breed_idTobreeds", fields: [breed_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  animals_animals_father_idToanimals         animals?                   @relation("animals_father_idToanimals", fields: [father_id], references: [id], onUpdate: NoAction)
  other_animals_animals_father_idToanimals   animals[]                  @relation("animals_father_idToanimals")
  animals_animals_mother_idToanimals         animals?                   @relation("animals_mother_idToanimals", fields: [mother_id], references: [id], onUpdate: NoAction)
  other_animals_animals_mother_idToanimals   animals[]                  @relation("animals_mother_idToanimals")
  organizations                              organizations?             @relation(fields: [organization_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users                                      users?                     @relation(fields: [owner_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  species                                    species                    @relation(fields: [species_id], references: [id], onUpdate: NoAction)
  breeds_animals_breed_id_species_idTobreeds breeds?                    @relation("animals_breed_id_species_idTobreeds", fields: [breed_id, species_id], references: [id, species_id], onUpdate: NoAction, map: "fk_animals_breed_species")
  digital_assets                             digital_assets[]
  listings                                   listings[]
  ownership_transfers                        ownership_transfers[]

  @@index([breed_text_localized], map: "idx_animals_breed_text")
  @@index([health_records], map: "idx_animals_health_records", type: Gin)
  @@index([owned_since], map: "idx_animals_owned_since")
  @@index([owner_id], map: "idx_animals_owner")
  @@index([reproductive_data], map: "idx_animals_reproductive_data", type: Gin)
  @@index([species_id, breed_id], map: "idx_animals_species_breed")
}

