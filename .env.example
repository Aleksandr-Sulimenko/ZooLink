# ZooLink MVP environment template. Copy to .env and fill real values. NEVER commit .env (see .gitignore).
# Provider choices follow ADR-0008 (RF-appropriate). All secrets are placeholders.

# ---- App ----
NODE_ENV=production
PORT=3000
PUBLIC_DOMAIN=zoolink.example.ru          # used by Caddy for automatic TLS

# ---- PostgreSQL ----
POSTGRES_USER=zoolink
POSTGRES_PASSWORD=__change_me__
POSTGRES_DB=zoolink
# App connection string (host = compose service name)
DATABASE_URL=postgresql://zoolink:__change_me__@postgres:5432/zoolink?schema=public

# ---- Redis ----
REDIS_PASSWORD=__change_me__
REDIS_URL=redis://:__change_me__@redis:6379

# ---- Object storage (S3-compatible: MinIO dev / Yandex Object Storage prod) ----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=__change_me__
S3_SECRET_KEY=__change_me__
S3_BUCKET=zoolink-media
S3_REGION=ru-central1

# ---- Auth / JWT (ADR-0001, security_specification.md) ----
JWT_ACCESS_SECRET=__change_me__generate_a_32+_char_random_secret__
JWT_REFRESH_SECRET=__change_me__generate_another_32+_char_secret__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PHONE_HASH_PEPPER=__change_me__generate_a_32+_char_secret_pepper__

# ---- SMS (SMS.RU — ADR-0008) ----
SMS_PROVIDER=smsru
SMSRU_API_ID=__change_me__
SMS_FROM=                                  # optional approved sender name; empty = SMS.RU default

# ---- Email (Unisender — ADR-0008) ----
EMAIL_PROVIDER=unisender
UNISENDER_API_KEY=__change_me__
UNISENDER_LIST_ID=                         # list id used for the unsubscribe footer
EMAIL_FROM=noreply@zoolink.example.ru      # verified sender address (required for real send)
EMAIL_FROM_NAME=ZooLink

# ---- Maps (Yandex.Maps — ADR-0008) ----
YANDEX_MAPS_API_KEY=__change_me__

# ---- OAuth ----
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_TELEGRAM_BOT_TOKEN=
OAUTH_VK_CLIENT_ID=
OAUTH_VK_CLIENT_SECRET=

# ---- Payments (Фаза 2+, gated by feature_toggles.payments — ЮKassa, ADR-0008) ----
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ---- Observability ----
SENTRY_DSN=
